VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional, local dev only (put real values in .env.local, which is git-ignored).
# When set, the app auto signs-in on `npm run dev` so you skip the magic link.
# Ignored entirely in production builds (gated behind import.meta.env.DEV).
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=
